# Copy this file to .env and fill in values for local development.
# When running via docker-compose, these vars are injected automatically.

# -----------------------------------------------------------
# Local Development (uses Aiven PostgreSQL)
# -----------------------------------------------------------
# Leave blank to use the default Aiven URL hardcoded in database.py,
# or override here:
# DATABASE_URL=postgres://avnadmin:AVNS_...@pg-...aivencloud.com:27736/defaultdb?sslmode=require

# -----------------------------------------------------------
# Docker Deployment (set automatically by docker-compose.yml)
# -----------------------------------------------------------
# DATABASE_URL=postgresql://mapper:mapperpass@db:5432/mappingdb
# API_URL=http://api:8000
